rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- MASTER CATCH-ALL (DEFAULT DENY) ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin list mapping
    function isAdminEmail(email) {
      return email in ["thienkhoatgk@gmail.com", "queenkily@gmail.com"];
    }
    
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email_verified == true && isAdminEmail(request.auth.token.email);
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'companyName', 'representative', 'group', 'role']) &&
               data.uid == request.auth.uid &&
               data.email is string &&
               data.companyName is string &&
               data.role in ['admin', 'member'];
      }
      
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Allow updating specific fields for members
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['companyName', 'representative', 'phone', 'totalScore'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // 2. Reports Collection
    match /reports/{reportId} {
      function isValidReport(data) {
        return data.keys().hasAll(['userId', 'week', 'date', 'total']) &&
               data.userId == request.auth.uid &&
               isValidId(data.userId);
      }
      
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Each user can query their own, rules enforce via 'resource.data.userId == request.auth.uid' in query if needed
      // Actually, list should be strict
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidReport(incoming());
      allow update: if (isAdmin() || (isOwner(existing().userId) && existing().status == 'pending')) && (
        isAdmin() || 
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['presenceStatus', 'infoCount', 'fbShares', 'oppCount', 'targetedGuests', 'nonTargetedGuests', 'normalMeetings', 'jointHosting', 'jointTrip', 'officeMeeting', 'giverAmount', 'isGiverExternal', 'giverRecipientId', 'receiverAmount', 'isReceiverExternal', 'receiverGiverId', 'piggyAmount', 'isPiggyExternal', 'evidence', 'meetingEvidence', 'hostingEvidence', 'tripEvidence', 'officeEvidence', 'total', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }

    // 3. Meetings Collection
    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 4. Guests Collection
    match /guests/{guestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().invitedBy == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().invitedBy == request.auth.uid);
    }

    // 5. Monthly Summaries Collection
    match /monthly_summaries/{summaryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 6. Notifications Collection
    match /notifications/{notifId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn(); // Members can notify each other of linked records
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // 7. Mail Collection (System usage)
    match /mail/{mailId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // 8. Connection Test
    match /test/connection {
      allow get: if isSignedIn();
    }
  }
}
