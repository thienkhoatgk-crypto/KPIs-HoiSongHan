rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- MASTER CATCH-ALL (DEFAULT DENY) ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdminEmail(email) {
      return email in ["thienkhoatgk@gmail.com", "queenkily@gmail.com"];
    }
    
    function isAdmin() { 
      return isSignedIn() && isAdminEmail(request.auth.token.email);
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAny(['uid', 'email', 'companyName', 'representative', 'group', 'role', 'phone']) &&
               data.uid == request.auth.uid &&
               data.email is string &&
               data.companyName is string &&
               data.role in ['admin', 'member'];
      }
      
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['companyName', 'representative', 'phone', 'totalScore', 'updatedAt'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // 2. Reports Collection
    match /reports/{reportId} {
      function isValidReport(data) {
        return data.keys().hasAll(['userId', 'week', 'date', 'total']) &&
               data.userId == request.auth.uid &&
               isValidId(data.userId);
      }
      
      // ✅ SỬA: Bổ sung đầy đủ tất cả fields mà App.tsx gửi trong reportData
      function allowedMemberFields() {
        return [
          'presenceStatus', 'infoCount', 'fbShares', 'oppCount',
          'referralReceivers', 'targetedGuests', 'nonTargetedGuests',
          'normalMeetings', 'jointHosting', 'jointTrip', 'officeMeeting',
          'meetingParticipantIds', 'hostingParticipantIds', 'tripParticipantIds', 'officeParticipantIds',
          'giverAmount', 'isGiverExternal', 'giverRecipientId', 'giverEvidence',
          'receiverAmount', 'isReceiverExternal', 'receiverGiverId', 'receiverEvidence',
          'piggyAmount', 'isPiggyExternal', 'piggyEvidence',
          'bonusPoints', 'penaltyPoints',
          'evidence', 'meetingEvidence', 'hostingEvidence', 'tripEvidence', 'officeEvidence',
          'total', 'updatedAt', 'lastUpdatedBy', 'status', 'adminNote',
          'confirmations', 'lastEditedDate'
        ];
      }
      
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidReport(incoming());
      allow update: if isAdmin() || 
                    (isOwner(existing().userId) && existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(allowedMemberFields())) ||
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['confirmations', 'lastEditedDate', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // 3. Meetings Collection
    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 4. Guests Collection
    match /guests/{guestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().invitedBy == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().invitedBy == request.auth.uid);
    }

    // 4b. Leave Requests Collection
    match /leaveRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid && existing().status == 'pending');
    }

    // 5. Monthly Summaries Collection
    match /monthly_summaries/{summaryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 6. Notifications Collection
    match /notifications/{notifId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // 7. Mail Collection
    match /mail/{mailId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // 8. Invitations Collection
    match /invitations/{invitationId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && existing().email == request.auth.token.email && incoming().diff(existing()).affectedKeys().hasOnly(['status']));
    }

    // 9. KPI Settings Collection
    match /kpi_settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 10. Elections Collection (Voting state)
    match /elections/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 11. Election Votes Collection
    match /election_votes/{voteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().voterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 12. Connection Test
    match /test/connection {
      allow get: if isSignedIn();
    }
  }
}
