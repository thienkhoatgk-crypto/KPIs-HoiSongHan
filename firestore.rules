rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // PRIMITIVES & HELPERS
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "thienkhoatgk@gmail.com" ||
        request.auth.token.email == "queenkily@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // COLLECTION RULES
    // ===============================================================

    // THÀNH VIÊN
    match /users/{userId} {
      // Cho phép đọc nếu đã đăng nhập (isSignedIn)
      allow read: if isSignedIn();
      
      // Chỉ chính chủ hoặc Admin mới được tạo/sửa thông tin
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin());
    }

    // BÁO CÁO KPI
    match /reports/{reportId} {
      // Xem báo cáo: Mọi người trong hội đều có thể xem để minh bạch (Peer review)
      allow get, list: if isSignedIn();
      
      // Tạo báo cáo: Chỉ cho chính mình
      allow create: if isSignedIn() && 
                    request.resource.data.userId == request.auth.uid;
      
      // Sửa/Xóa: Quy định cũ chỉ Admin được sửa để đảm bảo tính trung thực
      allow update, delete: if isAdmin();
    }

    // LỊCH HỌP
    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // KHÁCH MỜI
    match /guests/{guestId} {
      allow read: if isSignedIn();
      // Cho phép hội viên đăng ký khách mời
      allow create: if isSignedIn();
      // Sửa/Xóa: Người mời hoặc Admin
      allow update, delete: if isAdmin() || resource.data.invitedBy == request.auth.uid;
    }

    // TỔNG HỢP THÁNG
    match /monthly_summaries/{summaryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // THÔNG BÁO (Nếu có collection này)
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
    }

    // EMAIL (Firebase Extension)
    match /mail/{mailId} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }
  }
}
